    end
    object MemoNotes: TMemo
      Left = 34
      Height = 218
      Top = 174
      Width = 650
      Anchors = [akTop, akLeft, akRight, akBottom]
      Lines.Strings = (
        'Checklist visual sugerido:'
        ''
        '1. Use Selecionar imagem para mostrar e selecionar o grupo Ferramentas de Imagem.'
        '2. Use Selecionar tabela para mostrar e selecionar o grupo Ferramentas de Tabela.'
        '3. Exiba os dois grupos e verifique se os cabeçalhos não se sobrepõem.'
        '4. Use Limpar contexto para ocultar todos os grupos contextuais.'
        '5. Passe o mouse sobre Novo, Abrir, Colar e Imprimir para testar ScreenTips.'
        '6. Pressione Alt para conferir KeyTips nas abas normais e contextuais, incluindo KeyTips com dois caracteres como EX e PR.'
        '7. Redimensione a janela e observe se o layout continua estável.'
      )
      ReadOnly = True
      ScrollBars = ssAutoVertical
      TabOrder = 3
    end
