  object LazRibbonBackstageView1: TLazRibbonBackstageView
    Left = 0
    Height = 506
    Top = 112
    Width = 1040
    Align = alClient
    OverlayMode = bomCoverClientArea
    ActivePageIndex = 0
    BackstageTabCaption = 'Arquivo'
    BackButtonHint = 'Voltar'
    NavigationWidth = 178
    ItemHeight = 42
    LinkedToolbar = LazRibbon1
    SkinManager = LazRibbonSkinManager1
    Visible = False
    Buttons = <
      item
        Caption = 'Informações'
        Page = LazRibbonBackstagePageInfo
      end
      item
        Caption = 'Recentes'
        Page = LazRibbonBackstagePageRecent
      end
      item
        Caption = 'Opções'
        Page = LazRibbonBackstagePageOptions
        BeginGroup = True
      end
      item
        Kind = bbkSeparator
      end
      item
        Kind = bbkCommand
        Action = actSave
        CloseBackstageOnClick = False
      end
      item
        Kind = bbkCommand
        Action = actPrint
        CloseBackstageOnClick = False
      end
      item
        Kind = bbkCommand
        Action = actExit
        Section = bbsBottom
      end>
    object LazRibbonBackstagePageInfo: TLazRibbonBackstagePage
      Left = 178
      Height = 506
      Top = 0
      Width = 862
      Caption = 'Informações'
      object LabelInfoTitle: TLabel
        Left = 36
        Height = 30
        Top = 32
        Width = 220
        Caption = 'Informações'
        Font.Height = -24
        Font.Name = 'Segoe UI'
        Font.Style = [fsBold]
