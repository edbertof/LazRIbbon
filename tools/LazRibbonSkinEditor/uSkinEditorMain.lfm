  object EditorBackstage: TLazRibbonBackstageView
    Left = 260
    Height = 420
    Top = 360
    Width = 900
    AppearanceSource = asSkinManager
    BackstageTabCaption = 'Arquivo'
    BackButtonHint = 'Voltar'
    Buttons = <    
      item
        Caption = 'Informações'
        Page = BackstagePageInfo
      end    
      item
        Caption = 'Nova skin pela base...'
        Kind = bbkCommand
        OnExecute = btnNewFromBaseClick
      end    
      item
        Caption = 'Abrir skin...'
        Kind = bbkCommand
        OnExecute = btnOpenClick
      end    
      item
        Caption = 'Salvar como...'
        Kind = bbkCommand
        OnExecute = btnSaveAsClick
      end    
      item
        Kind = bbkSeparator
      end    
      item
        Caption = 'Exportar skins internos...'
        Kind = bbkCommand
        OnExecute = btnExportBuiltInsClick
      end    
      item
        Caption = 'Ajustes avançados do Appearance...'
        Kind = bbkCommand
        Section = bbsBottom
        OnExecute = btnEditFullAppearanceClick
      end    
      item
        Caption = 'Regerar Appearance pela paleta'
        Kind = bbkCommand
        Section = bbsBottom
        OnExecute = btnApplyPaletteToAppearanceClick
      end>
    Align = alNone
    BorderSpacing.Left = 8
    BorderSpacing.Top = 4
    BorderSpacing.Right = 8
    BorderSpacing.Bottom = 8
    Font.Height = -12
    Font.Name = 'Segoe UI'
    ItemHeight = 48
    LinkedToolbar = PreviewToolbar
    NavigationWidth = 220
    ParentFont = False
    ParentShowHint = False
    ShowHint = True
    SkinManager = PreviewSkinManager
    Visible = False
