object Form1: TForm1
  Left = 300
  Height = 360
  Top = 200
  Width = 760
  Caption = 'LazRibbon Demo - Popup Menu'
  ClientHeight = 360
  ClientWidth = 760
  Color = clBtnFace
  LCLVersion = '4.6.0.0'
  object LazRibbon1: TLazRibbon
    Left = 0
    Height = 112
    Top = 0
    Width = 760
    Align = alTop
    ApplicationButton.Caption = 'Arquivo'
    ApplicationButton.Visible = True
    ApplicationButton.Mode = abmPopupMenu
    ApplicationButton.Menu = LazRibbonPopupMenu1
    MenuButtonCaption = 'Arquivo'
    MenuButtonStyle = mbsCaptionDropdown
    MenuButtonDropdownMenu = LazRibbonPopupMenu1
    ShowMenuButton = True
    Tabs = (
      'LazRibbonTabHome'
    )
    TabIndex = 0
    object LazRibbonTabHome: TLazRibbonTab
      Caption = 'Início'
      Panes = (
        'LazRibbonPaneClipboard'
      )
      object LazRibbonPaneClipboard: TLazRibbonPane
        Caption = 'Área de transferência'
        Items = (
          'LazRibbonLargeButtonPaste'
        )
        object LazRibbonLargeButtonPaste: TLazRibbonLargeButton
          Caption = 'Colar'
          DropdownMenu = LazRibbonPopupMenu1
        end
      end
    end
  end
  object LazRibbonPopupMenu1: TLazRibbonPopupMenu
    left = 248
    top = 168
    object MenuItemNovo: TMenuItem
      Caption = 'Novo'
    end
    object MenuItemAbrir: TMenuItem
      Caption = 'Abrir'
    end
    object MenuItemSalvar: TMenuItem
      Caption = 'Salvar'
    end
  end
end
