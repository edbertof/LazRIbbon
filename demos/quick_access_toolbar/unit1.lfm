object Form1: TForm1
  Left = 300
  Height = 360
  Top = 200
  Width = 840
  Caption = 'LazRibbon Demo - Quick Access Toolbar'
  OnCreate = FormCreate
  OnClose = FormClose
  ClientHeight = 360
  ClientWidth = 840
  Color = clBtnFace
  LCLVersion = '4.6.0.0'
  object ActionList1: TActionList
    Left = 32
    Top = 160
    object ActionNew: TAction
      Caption = 'Novo'
      Hint = 'Criar novo documento'
      ImageIndex = 0
      OnExecute = ActionExecute
    end
    object ActionOpen: TAction
      Caption = 'Abrir'
      Hint = 'Abrir arquivo'
      ImageIndex = 1
      OnExecute = ActionExecute
    end
    object ActionSave: TAction
      Caption = 'Salvar'
      Hint = 'Salvar alterações'
      ImageIndex = 2
      OnExecute = ActionExecute
    end
    object ActionUndo: TAction
      Caption = 'Desfazer'
      Hint = 'Desfazer última ação'
      ImageIndex = 3
      OnExecute = ActionExecute
    end
    object ActionRedo: TAction
      Caption = 'Refazer'
      Hint = 'Refazer última ação'
      ImageIndex = 4
      OnExecute = ActionExecute
    end
    object ActionPrint: TAction
      Caption = 'Imprimir'
      Hint = 'Imprimir documento'
      ImageIndex = 5
      OnExecute = ActionExecute
    end
    object ActionEmail: TAction
      Caption = 'Email'
      Hint = 'Enviar por email'
      ImageIndex = 6
      OnExecute = ActionExecute
    end
    object ActionTouchMouse: TAction
      Caption = 'Modo Toque/Mouse'
      Hint = 'Alternar espaçamento para uso com mouse ou toque'
      ImageIndex = 7
      OnExecute = ActionExecute
    end
    object ActionTouchModeMouse: TAction
      Caption = 'Mouse'
      Hint = 'Faixa de opções e comandos padrão. Otimizada para uso com mouse.'
      ImageIndex = 8
      OnExecute = ActionExecute
    end
    object ActionTouchModeTouch: TAction
      Caption = 'Toque'
      Hint = 'Mais espaço entre os comandos. Otimizada para uso com toque.'
      ImageIndex = 9
      OnExecute = ActionExecute
    end
  end
  object PopupTouchMouse: TPopupMenu
    Left = 272
    Top = 160
    object MenuMouse: TMenuItem
      Action = ActionTouchModeMouse
    end
    object MenuTouch: TMenuItem
      Action = ActionTouchModeTouch
    end
  end
  object LazRibbonSkinManager1: TLazRibbonSkinManager
    ActiveSkin = sbsOfficeBlue
    Left = 152
    Top = 160
  end
  object LazRibbon1: TLazRibbon
    Left = 0
    Height = 112
    Top = 0
    Width = 840
    Align = alTop
    ApplicationButton.Caption = 'Arquivo'
    ApplicationButton.Visible = True
    QuickAccessToolBar.Visible = True
    QuickAccessToolBar.CustomizeActionList = ActionList1
    QuickAccessToolBar.ShowCustomizeButton = True
    QuickAccessToolBar.OnCustomizeClick = QuickAccessCustomize
    QuickAccessToolBar.OnMoreCommandsClick = QuickAccessMoreCommands
    QuickAccessToolBar.Items = <
      item
        Action = ActionNew
        LinkedItem = LazRibbonLargeButtonNew
      end
      item
        Action = ActionOpen
        LinkedItem = LazRibbonLargeButtonOpen
      end
      item
        Action = ActionSave
        LinkedItem = LazRibbonSmallButtonSave
      end
      item
        Action = ActionUndo
        LinkedItem = LazRibbonSmallButtonUndo
      end
      item
        Action = ActionRedo
      end
      item
        LinkedItem = LazRibbonSmallButtonTouchMouse
      end>
    SkinManager = LazRibbonSkinManager1
    Tabs = (
      'LazRibbonTabHome'
    )
    TabIndex = 0
    object LazRibbonTabHome: TLazRibbonTab
      Caption = 'Página Inicial'
      Panes = (
        'LazRibbonPaneFile'
      )
      object LazRibbonPaneFile: TLazRibbonPane
        Caption = 'Arquivo'
        Items = (
          'LazRibbonLargeButtonNew'
          'LazRibbonLargeButtonOpen'
          'LazRibbonSmallButtonSave'
          'LazRibbonSmallButtonUndo'
          'LazRibbonSmallButtonTouchMouse'
        )
        object LazRibbonLargeButtonNew: TLazRibbonLargeButton
          Action = ActionNew
          Caption = 'Novo'
        end
        object LazRibbonLargeButtonOpen: TLazRibbonLargeButton
          Action = ActionOpen
          Caption = 'Abrir'
        end
        object LazRibbonSmallButtonSave: TLazRibbonSmallButton
          Action = ActionSave
          Caption = 'Salvar'
        end
        object LazRibbonSmallButtonUndo: TLazRibbonSmallButton
          Action = ActionUndo
          Caption = 'Desfazer'
        end
        object LazRibbonSmallButtonTouchMouse: TLazRibbonSmallButton
          Action = ActionTouchMouse
          ButtonKind = bkDropdown
          Caption = 'Modo'
          DropdownMenu = PopupTouchMouse
          Hint = 'Alternar espaçamento entre comandos'
        end
      end
    end
  end
end
