      end
      object LabelInfoText: TLabel
        Left = 38
        Height = 64
        Top = 78
        Width = 650
        Caption = 'O BackStage foi configurado para cobrir a área cliente. A coluna esquerda separa páginas, comandos diretos e comando inferior.'
        Font.Height = -13
        Font.Name = 'Segoe UI'
        ParentFont = False
        WordWrap = True
      end
      object LabelInfoDetails: TLabel
        Left = 38
        Height = 88
        Top = 156
        Width = 650
        Caption = 'Este demo deve ser usado como vitrine visual e como teste manual rápido depois da instalação do pacote. Ele não substitui os demos específicos, mas ajuda a perceber imediatamente a aparência geral da suíte.'
        Font.Height = -12
        Font.Name = 'Segoe UI'
        ParentFont = False
        WordWrap = True
      end
    end
